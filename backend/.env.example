MONGODB_URI=mongodb://localhost:27017
DB_NAME=kdrama_ranking
# Required: protects DELETE, RESET, and REFRESH endpoints.
ADMIN_API_KEY=
# TMDB API key (required for actress search, gallery, drama metadata)
TMDB_API_KEY=
# Anthropic API key for AI chat
ANTHROPIC_API_KEY=
# Firebase Admin SDK (from service account JSON)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Comma-separated allowed origins for CORS (default: localhost dev servers)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
